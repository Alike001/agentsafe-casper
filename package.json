{
  "name": "agentpay-casper",
  "version": "0.1.0",
  "private": true,
  "description": "Wallet-owned spending mandates for AI agents on Casper.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node apps/api/server.js",
    "start": "node apps/api/server.js",
    "lint": "node scripts/lint.js",
    "typecheck": "node scripts/typecheck.js",
    "test": "node --test tests/*.test.js",
    "build": "node scripts/build.js",
    "proof:readiness": "node scripts/proof-readiness.js",
    "proof:demo": "node scripts/write-demo-proof.js",
    "contracts:test": "cargo test --manifest-path contracts/agent-safe-core/Cargo.toml",
    "contracts:odra:test": "cd contracts/agent-safe-odra && cargo test",
    "green-light": "npm run lint && npm run typecheck && npm test && npm run contracts:test && npm run contracts:odra:test && npm run build && npm run proof:readiness"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@make-software/casper-x402": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/core": "^2.19.0",
    "@x402/express": "^2.19.0",
    "express": "^5.1.0",
    "openai": "^6.48.0",
    "zod": "^3.25.76"
  }
}
